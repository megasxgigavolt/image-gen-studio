{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Auto Gen Studio",
  "version": "1.2.5",
  "identifier": "studio.autogen.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Auto Gen Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "maximized": true,
        "fullscreen": false,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "resources": {
      "../../../services/python-engine/auto_gen_engine/scene_grouping_engine.py": "python-engine/auto_gen_engine/scene_grouping_engine.py",
      "../../../services/python-engine/google-service-account.json": "google-service-account.json"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installerHooks": "installer-hooks.nsi"
      }
    }
  }
}
